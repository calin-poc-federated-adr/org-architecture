@startuml
title Event bus for cross-service integration

skinparam shadowing false
skinparam componentStyle rectangle

actor "External Client" as Client

rectangle "Platform" {
  component "Order Service" as Order
  component "Payment Service" as Payment
  component "Shipping Service" as Shipping
  component "Notification Service" as Notification
  queue "Event Bus" as Bus
}

Client --> Order : Create order
Order --> Bus : Publish OrderCreated
Bus --> Payment : Consume OrderCreated
Payment --> Bus : Publish PaymentConfirmed
Bus --> Shipping : Consume PaymentConfirmed
Shipping --> Bus : Publish ShipmentDispatched
Bus --> Notification : Consume business events

@enduml